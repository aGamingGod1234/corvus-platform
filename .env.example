# Copy to .env for Compose. These values are local-demo secrets, not production credentials.
CORVUS_BOOTSTRAP_TOKEN=replace-with-a-one-time-pairing-value
CORVUS_SESSION_SECRET=replace-with-at-least-32-random-bytes
CORVUS_OAUTH_STATE_SECRET=replace-with-a-distinct-32-byte-random-secret
CORVUS_PORT=8080

# Hosted web identity. Set the whole group or leave the whole group unset.
CORVUS_PUBLIC_ORIGIN=https://app.example.com
CORVUS_GOOGLE_CLIENT_ID=replace-with-google-client-id
CORVUS_GOOGLE_CLIENT_SECRET_REF=env://CORVUS_GOOGLE_CLIENT_SECRET
CORVUS_GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
CORVUS_GOOGLE_REDIRECT_URIS=https://app.example.com/api/v2/auth/google/callback
CORVUS_OAUTH_TRANSACTION_SECRET=replace-with-a-distinct-32-byte-random-secret

# Vercel's same-origin /api/v2 proxy forwards only to this validated origin.
CORVUS_RAILWAY_ORIGIN=https://api.example.com
